# ==============================================================================
# Terraform S3 backend configuration — generated by Ansible
# Injected at init time via backend_config_files parameter.
# Do not edit manually — source is ansible/templates/backend.hcl.j2
# ==============================================================================

bucket = "{{ minio_tf_bucket }}"
key    = "{{ minio_tf_key }}"
region = "us-east-1"

endpoints = {
  s3 = "{{ minio_endpoint }}"
}

access_key = "{{ vault_minio_access_key }}"
secret_key = "{{ vault_minio_secret_key }}"

insecure                    = true
skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
skip_requesting_account_id  = true
skip_s3_checksum            = true
use_path_style              = true
workspace_key_prefix        = "{{ minio_tf_workspace_prefix }}"
