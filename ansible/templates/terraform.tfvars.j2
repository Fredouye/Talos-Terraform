# ==============================================================================
# terraform.tfvars — generated by Ansible, do not edit manually
# Source: ansible/templates/terraform.tfvars.j2
# ==============================================================================

# ─── vSphere ──────────────────────────────────────────────────────────────────
# vsphere_user and vsphere_password are fetched from OpenBao at runtime.
vsphere_server     = "{{ vsphere_server }}"
vsphere_datacenter = "{{ vsphere_datacenter }}"
vsphere_cluster    = "{{ vsphere_cluster }}"
vsphere_datastore  = "{{ vsphere_datastore }}"
vsphere_network    = "{{ vsphere_network }}"
vsphere_folder     = "{{ vsphere_folder }}"

vsphere_template_cp     = "{{ vsphere_template_cp }}"
vsphere_template_worker = "{{ vsphere_template_worker }}"

# ─── Networking ───────────────────────────────────────────────────────────────
gateway       = "{{ gateway }}"
dns           = {{ dns_servers | tojson }}
ntp_servers   = {{ ntp_servers | tojson }}
node_netmask  = {{ node_netmask }}
nic_mac_prefix = "{{ nic_mac_prefix }}"

cluster_vip       = "{{ cluster_vip }}"
control_plane_ips = {{ control_plane_ips | tojson }}
worker_ips        = {{ worker_ips | tojson }}

# ─── Cluster ──────────────────────────────────────────────────────────────────
cluster_name       = "{{ cluster_name }}"
talos_version      = "{{ talos_version }}"
kubernetes_version = "{{ kubernetes_version }}"

cp_schematic_id     = "{{ cp_schematic_id }}"
worker_schematic_id = "{{ worker_schematic_id }}"

# ─── VM sizing ────────────────────────────────────────────────────────────────
cp_cpu         = {{ cp_cpu }}
cp_memory      = {{ cp_memory }}
cp_disk_gb     = {{ cp_disk_gb }}

worker_cpu         = {{ worker_cpu }}
worker_memory      = {{ worker_memory }}
worker_disk_gb     = {{ worker_disk_gb }}
longhorn_disk_gb   = {{ longhorn_disk_gb }}

# ─── Rancher ──────────────────────────────────────────────────────────────────
rancher_url   = "{{ rancher_url }}"
# rancher_token is fetched from OpenBao at runtime via providers.tf
